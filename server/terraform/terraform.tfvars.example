# Prefer using environments/<name>.tfvars with the Makefile at server/Makefile.
# This file is kept for direct `terraform apply` usage if preferred.
# See environments/example.tfvars.example for the canonical template.

server_domain        = "home.example.com"
docker_user          = "john"
traefik_config_dir   = "/opt/traefik"
letsencrypt_email    = "you@example.com"
cloudflare_api_token = "your-cloudflare-api-token"
