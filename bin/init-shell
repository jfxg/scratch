#!/usr/bin/env bash
# init-shell: Apply backed-up dotfiles from this repo to the home directory.
# Defaults to dry-run. Pass --apply to make changes.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# DOTFILES_REPO env var overrides the default (parent of script dir).
# Needed when running from ~/bin where the parent is $HOME, not the repo.
REPO="${DOTFILES_REPO:-$(dirname "$SCRIPT_DIR")}"
AGENT_SANDBOX_REPO="${AGENT_SANDBOX_REPO:-$HOME/projects/agent-sandbox}"
HOME_DIR="$HOME"
DRY_RUN=true

# ── Argument parsing ──────────────────────────────────────────────────────────
for arg in "$@"; do
    case "$arg" in
        --apply) DRY_RUN=false ;;
        --help|-h)
            echo "Usage: $(basename "$0") [--apply]"
            echo ""
            echo "  Compares repo dotfiles against \$HOME and shows what would change."
            echo "  --apply   Write changes to \$HOME (default is dry-run)"
            echo ""
            echo "  Environment:"
            echo "    DOTFILES_REPO   Path to the dotfiles repo (default: parent of this script)."
            echo "                    Set automatically in ~/.zshrc.local on first run."
            exit 0
            ;;
        *) echo "Unknown argument: $arg" >&2; exit 1 ;;
    esac
done

# ── Colour helpers ────────────────────────────────────────────────────────────
green()  { printf '\033[0;32m%s\033[0m\n' "$*"; }
yellow() { printf '\033[0;33m%s\033[0m\n' "$*"; }
blue()   { printf '\033[0;34m%s\033[0m\n' "$*"; }
red()    { printf '\033[0;31m%s\033[0m\n' "$*"; }
dim()    { printf '\033[2m%s\033[0m\n'    "$*"; }

CHANGES=0

# ── File comparison and install ───────────────────────────────────────────────
# check_file <repo_src> <home_dest>
check_file() {
    local src="$1"   # file in repo
    local dest="$2"  # target path in $HOME

    if [[ ! -f "$src" ]]; then
        dim "  skip     $(relpath "$src") (not in repo)"
        return
    fi

    if [[ ! -f "$dest" ]]; then
        yellow "  MISSING  $dest"
        CHANGES=$((CHANGES + 1))
        if [[ "$DRY_RUN" == false ]]; then
            mkdir -p "$(dirname "$dest")"
            cp -p "$src" "$dest"
            green "           → created"
        fi
        return
    fi

    _content_differs=false
    _mode_differs=false
    diff -q "$src" "$dest" > /dev/null 2>&1 || _content_differs=true
    { [[ -x "$src" && ! -x "$dest" ]] || [[ ! -x "$src" && -x "$dest" ]]; } && _mode_differs=true

    if $_content_differs || $_mode_differs; then
        yellow "  CHANGED  $dest"
        if $_content_differs; then
            diff --unified=3 "$dest" "$src" | tail -n +3 | \
                sed 's/^+/\t\033[0;32m+\033[0m/; s/^-/\t\033[0;31m-\033[0m/; s/^@/\t\033[2m@\033[0m/' || true
        fi
        $_mode_differs && dim "           (execute bit changed)"
        CHANGES=$((CHANGES + 1))
        if [[ "$DRY_RUN" == false ]]; then
            cp -p "$src" "$dest"
            green "           → updated"
        fi
    else
        green "  ok       $dest"
    fi
}

# check_dir <repo_src_dir> <home_dest_dir>
check_dir() {
    local src="$1"
    local dest="$2"

    if [[ ! -d "$src" ]]; then
        dim "  skip     $(relpath "$src") (not in repo)"
        return
    fi

    # Compare each file in the repo dir against the destination
    local any=false
    while IFS= read -r -d '' file; do
        local rel="${file#$src/}"
        check_file "$src/$rel" "$dest/$rel"
        any=true
    done < <(find "$src" -type f -print0)

    if [[ "$any" == false ]]; then
        dim "  skip     $(relpath "$src") (empty)"
    fi
}

relpath() { echo "${1#$REPO/}"; }

# ── Main ──────────────────────────────────────────────────────────────────────
echo ""
if [[ "$DRY_RUN" == true ]]; then
    blue "==> Dry run — comparing repo dotfiles to \$HOME (pass --apply to write changes)"
else
    blue "==> Applying repo dotfiles to \$HOME"
fi
echo ""

blue "-- Shell --"
check_file "$REPO/shell/.zshrc"    "$HOME_DIR/.zshrc"
check_file "$REPO/shell/.zprofile" "$HOME_DIR/.zprofile"

blue "-- Agent sandbox repo --"
if [[ ! -d "$AGENT_SANDBOX_REPO/.git" ]]; then
    yellow "  MISSING  $AGENT_SANDBOX_REPO (jfxg/agent-sandbox not cloned)"
    CHANGES=$((CHANGES + 1))
    if [[ "$DRY_RUN" == false ]]; then
        mkdir -p "$(dirname "$AGENT_SANDBOX_REPO")"
        git clone https://github.com/jfxg/agent-sandbox.git "$AGENT_SANDBOX_REPO"
        green "           → cloned jfxg/agent-sandbox"
    fi
else
    green "  ok       $AGENT_SANDBOX_REPO"
fi

blue "-- ~/bin scripts --"
if [[ ! -d "$HOME_DIR/bin" ]]; then
    yellow "  MISSING  ~/bin (directory)"
    CHANGES=$((CHANGES + 1))
    if [[ "$DRY_RUN" == false ]]; then
        mkdir -p "$HOME_DIR/bin"
        green "           → created ~/bin"
    fi
fi
check_dir "$REPO/bin" "$HOME_DIR/bin"
check_file "$AGENT_SANDBOX_REPO/bin/agent"       "$HOME_DIR/bin/agent"
check_file "$AGENT_SANDBOX_REPO/bin/agent-build" "$HOME_DIR/bin/agent-build"

blue "-- PATH --"
if grep -q '\$HOME/bin\|~/bin' "$HOME_DIR/.zshrc" 2>/dev/null; then
    green "  ok       ~/bin in PATH via ~/.zshrc"
else
    yellow "  MISSING  ~/bin not found in ~/.zshrc PATH"
    CHANGES=$((CHANGES + 1))
    if [[ "$DRY_RUN" == false ]]; then
        printf '\nexport PATH="$HOME/bin:$PATH"\n' >> "$HOME_DIR/.zshrc"
        green "           → added to ~/.zshrc"
    fi
fi

blue "-- DOTFILES_REPO --"
if grep -q 'DOTFILES_REPO' "$HOME_DIR/.zshrc.local" 2>/dev/null || \
   grep -q 'DOTFILES_REPO' "$HOME_DIR/.zshrc" 2>/dev/null; then
    green "  ok       DOTFILES_REPO is set"
else
    yellow "  MISSING  DOTFILES_REPO not set (will pin to $REPO)"
    CHANGES=$((CHANGES + 1))
    if [[ "$DRY_RUN" == false ]]; then
        printf '\nexport DOTFILES_REPO="%s"\n' "$REPO" >> "$HOME_DIR/.zshrc.local"
        green "           → added to ~/.zshrc.local"
    fi
fi

blue "-- Agent sandbox --"
check_dir "$AGENT_SANDBOX_REPO/docker" "$HOME_DIR/.agent-sandbox/docker"

blue "-- oh-my-zsh custom themes --"
check_dir "$REPO/shell/oh-my-zsh/custom/themes" "$HOME_DIR/.oh-my-zsh/custom/themes"

blue "-- Git --"
check_file "$REPO/git/.gitconfig" "$HOME_DIR/.gitconfig"
check_file "$REPO/git/ignore"     "$HOME_DIR/.config/git/ignore"

blue "-- SSH config --"
check_file "$REPO/ssh/config" "$HOME_DIR/.ssh/config"

blue "-- Vim --"
check_file "$REPO/vim/.vimrc" "$HOME_DIR/.vimrc"

echo ""
if [[ $CHANGES -eq 0 ]]; then
    green "==> Everything is up to date."
elif [[ "$DRY_RUN" == true ]]; then
    yellow "==> $CHANGES difference(s) found. Run with --apply to update \$HOME."
else
    green "==> $CHANGES change(s) applied."
fi
echo ""
